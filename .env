# Root .env file for Vite (same level as package.json)
# Do not wrap values in quotes.

# Main app backend (existing admin/cashier/technician/product APIs)
VITE_MAIN_API_URL=http://localhost:5000/api
VITE_API_BASE_URL=http://localhost:5000/api

# Wholesale backend (Node.js + Express on port 5001)
# Required by wholesale axios client
VITE_API_URL=/wholesale-api
VITE_WHOLESALE_API_URL=/wholesale-api

# Vite dev server proxy targets
VITE_API_PROXY_TARGET=http://localhost:5000
VITE_WHOLESALE_PROXY_TARGET=http://localhost:5001

VITE_FIREBASE_API_KEY=AIzaSyCpd8d9B1vWlASt3KHrzg5ARG5tlPS75Tk
VITE_FIREBASE_AUTH_DOMAIN=a-max-mobile-otp.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=a-max-mobile-otp
VITE_FIREBASE_APP_ID=1:121238042337:web:1f89828ccbddf23b4269a0

# Optional Firebase fields
VITE_FIREBASE_STORAGE_BUCKET=a-max-mobile-otp.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=121238042337
VITE_FIREBASE_MEASUREMENT_ID=G-VY0GG8QL7X
VITE_WHOLESALE_API_RETRIES=2
VITE_WHOLESALE_API_RETRY_DELAY_MS=500
VITE_DEBUG_API=false

# Pin Vite dev server to match backend CORS allowlist
VITE_DEV_PORT=5177
VITE_DEV_STRICT_PORT=false


