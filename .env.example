# Copy this file to `.env` in the project root and replace with your values.
# Vite only exposes variables that start with VITE_.

# -------------------------------
# Frontend API Configuration
# -------------------------------
# Main app backend (existing modules)
VITE_MAIN_API_URL=http://localhost:5000/api
VITE_API_BASE_URL=http://localhost:5000/api

# Wholesale backend (required for wholesale login/dashboard)
# In development we recommend using the Vite proxy path below.
VITE_API_URL=/wholesale-api
VITE_WHOLESALE_API_URL=/wholesale-api

# Optional proxy targets for Vite dev server
VITE_API_PROXY_TARGET=http://localhost:5000
VITE_WHOLESALE_PROXY_TARGET=http://localhost:5001

# -------------------------------
# Backend Auth Configuration
# -------------------------------
JWT_SECRET=replace-with-a-long-random-secret
JWT_EXPIRES_IN=8h

# -------------------------------
# Backend MySQL (Product Module)
# -------------------------------
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=
MYSQL_DATABASE=amax_mobile
MYSQL_CONNECTION_LIMIT=10

# -------------------------------
# Optional Auth Seed Credentials
# -------------------------------
AUTH_CASHIER_UDUGAMA_USERNAME=cashier_udugama
AUTH_CASHIER_UDUGAMA_PASSWORD=1234
AUTH_CASHIER_GALLE_USERNAME=cashier_galle
AUTH_CASHIER_GALLE_PASSWORD=1234
AUTH_TECH_UDUGAMA_USERNAME=tech_udugama
AUTH_TECH_UDUGAMA_PASSWORD=1234
AUTH_TECH_GALLE_USERNAME=tech_galle
AUTH_TECH_GALLE_PASSWORD=1234

# -------------------------------
# Frontend Firebase (optional)
# -------------------------------
VITE_FIREBASE_API_KEY=AIzaSyA-REAL-EXAMPLE-FORMAT-1234567890
VITE_FIREBASE_AUTH_DOMAIN=your-project-id.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project-id.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=123456789012
VITE_FIREBASE_APP_ID=1:123456789012:web:abcdef1234567890abcd12
VITE_FIREBASE_MEASUREMENT_ID=G-ABC123DEF4
VITE_WHOLESALE_API_RETRIES=2
VITE_WHOLESALE_API_RETRY_DELAY_MS=500
VITE_DEBUG_API=false

# Pin dev server to the allowed CORS origin
VITE_DEV_PORT=5177
VITE_DEV_STRICT_PORT=false

